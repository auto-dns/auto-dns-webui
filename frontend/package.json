    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.7.0",
    "prettier": "^3.5.3",
    "sass-embedded": "^1.89.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
